// 1. Базова вартість = потужність (кВп) × ціна за кВп
cBase = power * pricePerKwp;

// 2. Кабельна траса = довжина (м) × 300 грн/м
cCable = cableLen * CONFIG.prices.cable_per_m;  // 300 грн/м

// 3. Батарея BESS = ємність (кВт·год) × 35 000 грн/кВт·год
cBESS = bessKwh * CONFIG.prices.BESS_per_kWh;   // 35 000 грн/кВт·год

// 4. Трансформатор (вводиться вручну)
cTransformer = transformerCost;

// Проміжна сума
subTotal = cBase + cCable + cBESS + cTransformer;

// 5. Проєктування та ТУ = 4% від проміжної суми
cDesign = subTotal * CONFIG.finance.design_pct;      // 0.04

// 6. Резерв непередбачених = 10% від проміжної суми
cContingency = subTotal * CONFIG.finance.contingency_pct;  // 0.10

// РАЗОМ CAPEX
capex = subTotal + cDesign + cContingency;

